name: Build Windows ISO

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: windows-latest

    steps:

    - name: Checkout repository
      uses: actions/checkout@v4

    - name: Free disk space
      run: |
        rm -rf "C:\Program Files\Android"
        rm -rf "C:\Program Files\Microsoft SDKs"

    - name: Run UUP dump script
      run: |
        cmd /c uup_download_windows.cmd

    - name: Upload ISO
      uses: actions/upload-artifact@v4
      with:
        name: windows_iso
        path: "*.iso"
